<!-- views/register.ejs -->
<div class="row justify-content-center">
  <div class="col-md-6 col-lg-5">
    <div class="card shadow-lg border-0 rounded-4 auth-card">
      <div class="card-body p-4">
        <h3 class="text-center mb-3 fw-bold">Create Account 🚀</h3>
        <p class="text-center text-muted small mb-4">
          Plan, prioritize and complete your tasks with style.
        </p>

        <form action="/register" method="POST" novalidate>
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input
              type="text"
              name="name"
              class="form-control form-control-lg"
              placeholder="Your name"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Email</label>
            <input
              type="email"
              name="email"
              class="form-control form-control-lg"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Password</label>
            <input
              type="password"
              name="password"
              class="form-control form-control-lg"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <input
              type="password"
              name="confirmPassword"
              class="form-control form-control-lg"
              required
            />
          </div>

          <button class="btn btn-primary w-100 btn-lg rounded-pill mt-2">
            Sign Up
          </button>
        </form>

        <div class="text-center mt-3 small">
          Already have an account?
          <a href="/login" class="fw-semibold">Login</a>
        </div>
      </div>
    </div>
  </div>
</div>
