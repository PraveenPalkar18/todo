<!-- views/partials/navbar.ejs -->
<nav class="navbar navbar-expand-lg navbar-dark bg-gradient-primary shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/dashboard">TaskFlow</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-center">
        <% if (typeof userName !== "undefined" && userName) { %>
          <li class="nav-item me-2">
            <span class="nav-link disabled small">
              <i class="bi bi-person-circle me-1"></i>
              <%= userName %>
            </span>
          </li>
          <li class="nav-item">
            <a class="btn btn-sm btn-outline-light rounded-pill" href="/logout">
              Logout
            </a>
          </li>
        <% } else { %>
          <li class="nav-item me-2">
            <a class="btn btn-sm btn-outline-light rounded-pill" href="/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="btn btn-sm btn-light rounded-pill" href="/register">Sign Up</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
